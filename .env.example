# Word App - Environment Configuration
# Copy this file to .env for local development
# .env is git-ignored and will NOT be committed

# ===================
# Database
# ===================
# Allow starting with an empty database (no learning_units). Default: false.
# WORD_APP_ALLOW_EMPTY_DB=true
WORD_APP_STRICT_VOCAB_INTEGRITY=false

# ===================
# Networking (LAN / iPad Access)
# ===================
# Bind address: "127.0.0.1" (default, local only) or "0.0.0.0" (LAN access)
# WORD_APP_HOST=0.0.0.0
# Server port (default: 8000)
# WORD_APP_PORT=8000
# CORS: add your Mac's LAN IP to allow cross-origin requests from iPad Safari
# WORD_APP_CORS_ALLOW_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://192.168.x.x:8000
# Enable iPad as a learning-only client (default: false)
# WORD_APP_IPAD_ENABLED=true

# ===================
# OpenAI Configuration (Optional)
# ===================
# Enable OpenAI for AI features (Study Mode, Free Chat, Vocabulary Validation)
WORD_APP_OPENAI_ENABLED=false
WORD_APP_OPENAI_API_KEY=sk-xxxxx


# ===================
# Vocabulary Validation (Optional)
# ===================
# Enable AI-assisted spell-checking during PDF upload
# Requires OpenAI to be enabled
WORD_APP_VOCAB_VALIDATION_ENABLED=false

# ===================
# Language Settings
# ===================
WORD_APP_SOURCE_LANGUAGE=Polish
WORD_APP_TARGET_LANGUAGE=English

# ===================
# Ollama Configuration (Local AI)
# ===================
WORD_APP_OLLAMA_BASE_URL=http://localhost:11434
WORD_APP_OLLAMA_MODEL=llama3.2

# ===================
# Session Settings
# ===================
WORD_APP_SESSION_SIZE=50

# ===================
# Murf TTS Configuration (Audio Pronunciation)
# ===================
# Enable audio pronunciation in Study Mode
WORD_APP_MURF_ENABLED=false
# Murf API key (get from https://murf.ai)
WORD_APP_MURF_API_KEY=
# Default voice (see Murf docs for available voices)
WORD_APP_MURF_VOICE=en-US-marcus
# Default language code
WORD_APP_MURF_LANGUAGE=en-US

# ===================
# ElevenLabs TTS Configuration (Audio Pronunciation for Polish)
# ===================
# Enable ElevenLabs for Polish audio pronunciation
WORD_APP_ELEVENLABS_ENABLED=false
# ElevenLabs API key (get from https://elevenlabs.io)
WORD_APP_ELEVENLABS_API_KEY=
# Voice model (default: eleven_multilingual_v2)
WORD_APP_ELEVENLABS_MODEL=eleven_multilingual_v2
# Polish voice ID (required when enabled, get from ElevenLabs dashboard)
WORD_APP_ELEVENLABS_VOICE_PL=
